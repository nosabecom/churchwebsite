---
const gatherings = [
    {
        eyebrow: "Every Sunday",
        title: "Sunday Worship",
        time: "9:00 AM",
        note: "Breakfast Sunday is held on the last Sunday of each month.",
        accent: "sunrise",
    },
    {
        eyebrow: "Every Wednesday",
        title: "Mid-week Service",
        time: "7:00 PM",
        note: "A mid-week evening of prayer, worship, and the Word.",
        accent: "evening",
    },
    {
        eyebrow: "Last Friday monthly",
        title: "Power Night",
        time: "10:00 PM",
        note: "Join us for our monthly vigil and a focused time of prayer.",
        accent: "night",
    },
];
---

<section class="welcome-section" aria-labelledby="welcome-heading">
    <div class="welcome-copy">
        <p class="section-kicker">You’re welcome here</p>
        <h2 id="welcome-heading">There’s a place for you at Cornerstone.</h2>
        <p class="welcome-message">
            Come as you are and join a family growing in purpose, power, and praise.
            Here’s what’s happening each week.
        </p>
        <a class="directions-link" href="https://www.google.com/maps/search/?api=1&query=70-3904+Millar+Avenue+Saskatoon+SK+S7P+0B1" target="_blank" rel="noreferrer">
            Get directions
            <span aria-hidden="true">↗</span>
        </a>
    </div>

    <div
        class="gatherings-carousel"
        role="region"
        aria-roledescription="carousel"
        aria-label="Church services and events"
        aria-live="off"
        data-gatherings-carousel
    >
        <div class="gathering-slides">
            {gatherings.map((gathering, index) => (
                <article
                    class:list={["gathering-card", `gathering-card--${gathering.accent}`]}
                    aria-hidden={index === 0 ? "false" : "true"}
                    data-gathering-slide
                    data-active={index === 0 ? "" : undefined}
                >
                    <div class="card-topline">
                        <span>{gathering.eyebrow}</span>
                        <span class="event-number" aria-hidden="true">0{index + 1}</span>
                    </div>

                    <div class="card-content">
                        <p class="event-time">{gathering.time}</p>
                        <h3>{gathering.title}</h3>
                        <p class="event-note">{gathering.note}</p>
                    </div>

                    <address>
                        <span class="location-mark" aria-hidden="true"></span>
                        <span>70-3904 Millar Avenue<br />Saskatoon, SK S7P 0B1</span>
                    </address>
                </article>
            ))}
        </div>

        <div class="carousel-controls">
            <button type="button" aria-label="Previous gathering" data-gathering-prev>←</button>
            <div class="carousel-dots" role="group" aria-label="Choose a gathering">
                {gatherings.map((gathering, index) => (
                    <button
                        type="button"
                        aria-label={`Show ${gathering.title}`}
                        aria-current={index === 0 ? "true" : "false"}
                        data-gathering-dot
                    ></button>
                ))}
            </div>
            <button type="button" aria-label="Next gathering" data-gathering-next>→</button>
        </div>
    </div>
</section>

<script>
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    document.querySelectorAll<HTMLElement>("[data-gatherings-carousel]").forEach((carousel) => {
        const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-gathering-slide]"));
        const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-gathering-dot]"));
        let current = 0;
        let timer: number | undefined;

        const showSlide = (index: number) => {
            current = (index + slides.length) % slides.length;
            slides.forEach((slide, slideIndex) => {
                const isActive = slideIndex === current;
                slide.toggleAttribute("data-active", isActive);
                slide.setAttribute("aria-hidden", String(!isActive));
            });
            dots.forEach((dot, dotIndex) => {
                dot.setAttribute("aria-current", String(dotIndex === current));
            });
        };

        const stop = () => {
            if (timer !== undefined) window.clearInterval(timer);
            timer = undefined;
        };

        const start = () => {
            stop();
            if (!reducedMotion.matches && !document.hidden && !carousel.matches(":hover") && !carousel.contains(document.activeElement)) {
                timer = window.setInterval(() => showSlide(current + 1), 7000);
            }
        };

        carousel.querySelector("[data-gathering-prev]")?.addEventListener("click", () => {
            showSlide(current - 1);
            start();
        });
        carousel.querySelector("[data-gathering-next]")?.addEventListener("click", () => {
            showSlide(current + 1);
            start();
        });
        dots.forEach((dot, index) => dot.addEventListener("click", () => {
            showSlide(index);
            start();
        }));
        carousel.addEventListener("mouseenter", stop);
        carousel.addEventListener("mouseleave", start);
        carousel.addEventListener("focusin", stop);
        carousel.addEventListener("focusout", (event) => {
            if (!carousel.contains(event.relatedTarget as Node | null)) start();
        });
        reducedMotion.addEventListener("change", start);
        document.addEventListener("visibilitychange", start);
        start();
    });
</script>

<style>
    .welcome-section {
        display: grid;
        align-items: center;
        gap: clamp(2.5rem, 7vw, 7rem);
        max-width: 80rem;
        margin: 0 auto;
        padding: clamp(3.5rem, 8vw, 7rem) 1.5rem;
        color: white;
    }

    .welcome-copy {
        max-width: 36rem;
    }

    .section-kicker {
        margin: 0 0 0.85rem;
        color: #fbbf24;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    h2 {
        max-width: 11ch;
        margin: 0;
        font-size: clamp(2.4rem, 6vw, 4.75rem);
        font-weight: 800;
        letter-spacing: -0.055em;
        line-height: 0.98;
    }

    .welcome-message {
        max-width: 34rem;
        margin: 1.5rem 0 0;
        color: rgb(224 242 254 / 88%);
        font-size: 1.05rem;
        line-height: 1.75;
    }

    .directions-link {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        margin-top: 1.75rem;
        padding-bottom: 0.3rem;
        color: white;
        border-bottom: 2px solid #fbbf24;
        font-weight: 750;
        text-decoration: none;
    }

    .directions-link span {
        transition: transform 180ms ease;
    }

    .directions-link:hover span,
    .directions-link:focus-visible span {
        transform: translate(0.15rem, -0.15rem);
    }

    .gatherings-carousel {
        width: min(100%, 26rem);
        margin-inline: auto;
    }

    .gathering-slides {
        position: relative;
        aspect-ratio: 1;
        border-radius: 1.75rem;
        box-shadow: 0 2rem 5rem rgb(2 8 23 / 35%);
    }

    .gathering-card {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        padding: clamp(1.5rem, 5vw, 2.25rem);
        color: white;
        border: 1px solid rgb(255 255 255 / 14%);
        border-radius: inherit;
        opacity: 0;
        pointer-events: none;
        transform: translateX(1rem) scale(0.98);
        transition: opacity 400ms ease, transform 400ms ease;
    }

    .gathering-card::before,
    .gathering-card::after {
        position: absolute;
        content: "";
        border-radius: 999px;
        pointer-events: none;
    }

    .gathering-card::before {
        top: -15%;
        right: -18%;
        width: 58%;
        aspect-ratio: 1;
        background: rgb(255 255 255 / 12%);
    }

    .gathering-card::after {
        right: 18%;
        bottom: -4%;
        width: 0.65rem;
        aspect-ratio: 1;
        background: #fbbf24;
        box-shadow: 1.6rem -1.8rem 0 rgb(255 255 255 / 20%);
    }

    .gathering-card--sunrise { background: linear-gradient(145deg, #d43d2f, #991b1b); }
    .gathering-card--evening { background: linear-gradient(145deg, #087b9b, #075985); }
    .gathering-card--night { background: linear-gradient(145deg, #4338ca, #312e81); }

    .gathering-card[data-active] {
        z-index: 1;
        opacity: 1;
        pointer-events: auto;
        transform: none;
    }

    .card-topline,
    address {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
    }

    .card-topline {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.13em;
        text-transform: uppercase;
    }

    .event-number {
        color: rgb(255 255 255 / 52%);
        font-size: 0.7rem;
    }

    .card-content {
        position: relative;
        z-index: 1;
    }

    .event-time {
        margin: 0 0 0.25rem;
        color: #fde68a;
        font-size: clamp(2rem, 7vw, 3.25rem);
        font-weight: 850;
        letter-spacing: -0.055em;
        line-height: 1;
    }

    h3 {
        margin: 0;
        font-size: clamp(1.35rem, 4vw, 2rem);
        letter-spacing: -0.025em;
    }

    .event-note {
        max-width: 29ch;
        margin: 0.65rem 0 0;
        color: rgb(255 255 255 / 78%);
        font-size: 0.87rem;
        line-height: 1.55;
    }

    address {
        justify-content: flex-start;
        color: rgb(255 255 255 / 84%);
        font-size: 0.76rem;
        font-style: normal;
        line-height: 1.45;
    }

    .location-mark {
        width: 0.65rem;
        height: 0.65rem;
        margin-top: 0.2rem;
        flex: 0 0 auto;
        background: #fbbf24;
        border: 2px solid rgb(255 255 255 / 85%);
        border-radius: 999px 999px 999px 0;
        transform: rotate(-45deg);
    }

    .carousel-controls {
        display: grid;
        grid-template-columns: 2.75rem 1fr 2.75rem;
        align-items: center;
        gap: 1rem;
        margin-top: 1rem;
    }

    .carousel-controls > button {
        width: 2.75rem;
        height: 2.75rem;
        padding: 0;
        color: white;
        background: rgb(255 255 255 / 8%);
        border: 1px solid rgb(255 255 255 / 25%);
        border-radius: 999px;
        cursor: pointer;
        font-size: 1.1rem;
        transition: background 160ms ease, border-color 160ms ease;
    }

    .carousel-controls > button:hover,
    .carousel-controls > button:focus-visible {
        background: rgb(255 255 255 / 16%);
        border-color: rgb(255 255 255 / 55%);
    }

    .carousel-dots {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
    }

    .carousel-dots button {
        width: 0.5rem;
        height: 0.5rem;
        padding: 0;
        background: rgb(255 255 255 / 30%);
        border: 0;
        border-radius: 999px;
        cursor: pointer;
        transition: width 180ms ease, background 180ms ease;
    }

    .carousel-dots button[aria-current="true"] {
        width: 1.75rem;
        background: #fbbf24;
    }

    @media (min-width: 800px) {
        .welcome-section {
            grid-template-columns: minmax(0, 1fr) minmax(20rem, 26rem);
            padding-inline: 2.5rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .gathering-card,
        .directions-link span,
        .carousel-dots button {
            transition: none;
        }
    }
</style>

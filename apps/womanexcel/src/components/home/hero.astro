---
import Slideshow from "@churchwebsite/slideshow";
import Quote from "@churchwebsite/quote";

const slides = Array.from({ length: 10 }, (_, index) => ({
    src: `/images/placeholds/photo-${index + 1}.jpg`,
    alt: `Woman Excel conference highlight ${index + 1}`,
}));
---

<Slideshow
    slides={slides}
    label="Woman Excel conference highlights"
    class="woman-excel-slideshow mt-6 mb-20 mx-4 2xl:mx-auto max-w-400 rounded-3xl"
>
    <div class="absolute inset-0 bg-navy/20"></div>

    <div class="relative z-10 flex flex-col items-center mt-1.5 md:m-0 md:gap-6 pb-20 pt-10">
        <p class="border-none rounded-xl bg-navy text-white text-[13px] px-3 py-1.5 mb-8.5 md:mb-5.5 font-sans">Theme for this year</p>
        <img class="w-[85%] max-w-350" src="/images/the-word.svg" alt="The Word">
        <Quote
            quote="In the beginning was the Word, and the Word was with God, and the Word was God"
            citation="John 1:1"
            class="woman-excel-quote my-6 mx-8 md:m-0 max-w-[92%]"
        />
    </div>
</Slideshow>

                    <p class="speaker-nametag">Tobie Hainstock</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Desktop pauses on hover; touch devices have no hover, so tap toggles the scroll.
    document.querySelectorAll<HTMLElement>("[data-speaker-track]").forEach((track) => {
        track.addEventListener("pointerdown", (e) => {
            if (e.pointerType !== "mouse") track.toggleAttribute("data-paused");
        });
    });
</script>

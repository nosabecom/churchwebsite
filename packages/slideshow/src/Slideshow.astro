---
export interface Slide {
    src: string;
    alt: string;
    objectPosition?: string;
}

export interface Props {
    slides: Slide[];
    interval?: number;
    label?: string;
    aspectRatio?: string;
    class?: string;
}

const {
    slides,
    interval = 8000,
    label = "Featured images",
    aspectRatio,
    class: className,
} = Astro.props;

if (slides.length === 0) {
    throw new Error("Slideshow requires at least one slide.");
}
---

<section
    class:list={["slideshow", className]}
    aria-roledescription="carousel"
    aria-label={label}
    data-shared-slideshow
    data-interval={interval}
    style={aspectRatio ? `--slideshow-aspect-ratio: ${aspectRatio}` : undefined}
>
    <div class="slides" aria-live="off">
        {slides.map((slide, index) => (
            <img
                src={slide.src}
                alt={slide.alt}
                loading={index === 0 ? "eager" : "lazy"}
                data-slide
                data-active={index === 0 ? "" : undefined}
                aria-hidden={index === 0 ? "false" : "true"}
                style={slide.objectPosition ? `object-position: ${slide.objectPosition}` : undefined}
            />
        ))}
    </div>

    <div class="overlay">
        <slot />
    </div>

    {slides.length > 1 && (
        <>
            <button class="arrow previous" type="button" aria-label="Previous image" data-prev>
                <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="m15 18-6-6 6-6" />
                </svg>
            </button>

            <button class="arrow next" type="button" aria-label="Next image" data-next>
                <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="m9 18 6-6-6-6" />
                </svg>
            </button>

            <div class="dots" aria-label="Choose an image">
                {slides.map((_, index) => (
                    <button
                        type="button"
                        aria-label={`Go to image ${index + 1}`}
                        aria-current={index === 0 ? "true" : "false"}
                        data-dot
                    />
                ))}
            </div>
        </>
    )}
</section>

<script>
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    document.querySelectorAll<HTMLElement>("[data-shared-slideshow]").forEach((root) => {
        if (root.dataset.initialized === "true") return;
        root.dataset.initialized = "true";

        const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
        const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dot]"));
        const interval = Number(root.dataset.interval) || 8000;
        let current = 0;
        let timer: number | undefined;

        const show = (index: number) => {
            current = (index + slides.length) % slides.length;
            slides.forEach((slide, slideIndex) => {
                const active = slideIndex === current;
                slide.toggleAttribute("data-active", active);
                slide.setAttribute("aria-hidden", String(!active));
            });
            dots.forEach((dot, dotIndex) => {
                dot.setAttribute("aria-current", String(dotIndex === current));
            });
        };

        const stop = () => {
            if (timer !== undefined) window.clearInterval(timer);
            timer = undefined;
        };

        const start = () => {
            stop();
            const userIsInteracting = root.matches(":hover") || root.contains(document.activeElement);
            if (slides.length > 1 && !reducedMotion.matches && !document.hidden && !userIsInteracting) {
                timer = window.setInterval(() => show(current + 1), interval);
            }
        };

        root.querySelector("[data-prev]")?.addEventListener("click", () => {
            show(current - 1);
            start();
        });
        root.querySelector("[data-next]")?.addEventListener("click", () => {
            show(current + 1);
            start();
        });
        dots.forEach((dot, index) => dot.addEventListener("click", () => {
            show(index);
            start();
        }));

        root.addEventListener("mouseenter", stop);
        root.addEventListener("mouseleave", start);
        root.addEventListener("focusin", stop);
        root.addEventListener("focusout", (event) => {
            if (!root.contains(event.relatedTarget as Node | null)) start();
        });
        reducedMotion.addEventListener("change", start);
        document.addEventListener("visibilitychange", start);
        start();
    });
</script>

<style>
    .slideshow {
        position: relative;
        isolation: isolate;
        overflow: hidden;
        aspect-ratio: var(--slideshow-aspect-ratio, auto);
    }

    .slides,
    .slides::after {
        position: absolute;
        inset: 0;
    }

    [data-slide] {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 700ms ease-in-out;
    }

    [data-slide][data-active] {
        opacity: 1;
    }

    .overlay {
        position: relative;
        z-index: 1;
        min-height: 100%;
    }

    .arrow,
    .dots {
        position: absolute;
        z-index: 2;
        opacity: 0;
        transition: opacity 150ms ease-in-out, background-color 150ms ease-in-out;
    }

    .arrow {
        top: 50%;
        display: grid;
        width: 3rem;
        height: 3rem;
        padding: 0;
        color: white;
        background: rgb(8 42 78 / 60%);
        border: 0;
        border-radius: 9999px;
        cursor: pointer;
        place-items: center;
        transform: translateY(-50%);
    }

    .arrow:hover,
    .arrow:focus-visible {
        background: rgb(8 42 78 / 90%);
    }

    .arrow svg {
        width: 1.5rem;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 2.5;
    }

    .previous { left: 1.5rem; }
    .next { right: 1.5rem; }

    .dots {
        right: 0;
        bottom: 1rem;
        left: 0;
        display: flex;
        justify-content: center;
        gap: 0.35rem;
    }

    .dots button {
        width: 0.5rem;
        height: 0.5rem;
        padding: 0;
        background: rgb(255 255 255 / 50%);
        border: 0;
        border-radius: 9999px;
        cursor: pointer;
    }

    .dots button:hover,
    .dots button[aria-current="true"] {
        background: white;
    }

    .slideshow:hover .arrow,
    .slideshow:hover .dots,
    .slideshow:focus-within .arrow,
    .slideshow:focus-within .dots {
        opacity: 1;
    }

    @media (any-pointer: coarse) {
        .arrow,
        .dots { opacity: 1; }
    }

    @media (max-width: 767px) {
        .arrow {
            width: 1.75rem;
            height: 2.25rem;
        }

        .previous { left: 0.25rem; }
        .next { right: 0.25rem; }
    }

    @media (prefers-reduced-motion: reduce) {
        [data-slide] { transition: none; }
    }
</style>
